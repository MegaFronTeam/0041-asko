mixin sSets(data)
	// start sSets
	+b.SECTION.sSets.section#sSets&attributes(attributes)
		.container
			+b.section-title
				h2 Комплекты техники
				+e.text.row
					.col-auto
						p Выберите готовый или соберите комплект техники для
					.col
						+b.cat-btns
							+e.btn.active Прачечная
							+e.btn Кухня
			+e.block.bg-wrap
				+img("img/set-bg.jpg",'bg').img-bg
				+e.row.row
					+e.caption.col-xl-4
						+e.body
							.h1 Домашняя прачечная
							p Аско предлагает элегантное дизайнерское решение — возможность устанавливать сверху сушильную машину, а рядом сушильный шкаф.
						+e.footer.d-none.d-xl-block
							.row
								.col
									+e.btn.btn-outline-white.btn(href="#") Смотреть всё
								.col-auto
									.arrow-wrap
										+arrow
					.col-xl-8
						+e.slider--js.swiper
							.swiper-wrapper
								- for (var x = 0; x < 3; x++)
									.swiper-slide
										+b.ARTICLE.product-item--set
											+prod-head()
											+prod-img("set")
											+e.caption
												+e.text--lg Комплект
												+e.title--lg
													a.text-body(href="#")  Аsco Classik №1
												+e.icons.row
													+e.icon--rating.col-auto
														+icon("star")
														| 4.8
													+e.icon--comments.col-auto
														+icon("chart")
														| 4
													+e.icon--status.col-auto
														+e.ball(style="background: #35BE73")
														| В наличии
													p.small.d-none.d-md-block Комплект Asko Classic 1 — это отличное решение для тех, кто ценит качество, функциональность и стильный дизайн. Произведенный в Словении, этот комплект обеспечивает.
													+e.products.row.mb-2.d-none.d-lg-flex
														.col-auto
															+e.text.mb-1.smallest Стиральная машина
															+e.title--sm
																a.text-body(href="#") Asco W2084.W/3
														.col-auto
															+e.text.mb-1.smallest Сушильная машина
															+e.title--sm
																a.text-body(href="#") Asco T208C. W.
												+prod-footer()
					+e.footer.d-xl-none
							.row
								.col
									.swiper-pagination
								.col-auto
									a.text-white(href="#").small Все комплекты
	// end sSets
mixin sSets02(data)
	// start sSets
	+b.sSets.section#sSets&attributes(attributes)
		.container
			+b.section-title
				.row
					.col
						h4 Выгодные комплекты
					.col-auto.d-none.d-xl-block
						a(href="#") Все комплекты
			+e.slider--js.swiper
				.swiper-wrapper
					- for (var x = 0; x < 3; x++)
						.swiper-slide
							+b.ARTICLE.product-item--set
								+prod-head()
								+prod-img("set")
								+e.caption
									+e.text--lg Комплект
									+e.title--lg
										a.text-body(href="#")  Аsco Classik №1
									+e.icons.row
										+e.icon--rating.col-auto
											+icon("star")
											| 4.8
										+e.icon--comments.col-auto
											+icon("chart")
											| 4
										+e.icon--status.col-auto
											+e.ball(style="background: #35BE73")
											| В наличии
										p.small.d-none.d-md-block Комплект Asko Classic 1 — это отличное решение для тех, кто ценит качество, функциональность и стильный дизайн. Произведенный в Словении, этот комплект обеспечивает.
										+e.products.row.mb-2.d-none.d-lg-flex
											.col-auto
												+e.text.mb-1.smallest Стиральная машина
												+e.title--sm
													a.text-body(href="#") Asco W2084.W/3
											.col-auto
												+e.text.mb-1.smallest Сушильная машина
												+e.title--sm
													a.text-body(href="#") Asco T208C. W.
									+prod-footer()
			+e.footer.mt-4
					.row.gy-0
						.col.align-self-center
							.swiper-pagination
						.col-auto.d-xl-block.d-none
							.arrow-wrap
								+arrow
						.col-auto.d-xl-none
							a(href="#").small Все комплекты
	// end sSets