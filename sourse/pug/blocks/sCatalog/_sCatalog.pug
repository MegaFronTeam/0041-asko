mixin prod-img(i= 1)
	.product-item__img-wrap(href="#")
		//- если надо картинку по центру  вывести использовать обертку .img-wrap-center  - если нет- убираем
		.img-wrap-center 
			+img(`img/prod-${i}.png`)

mixin prod-caption()
	.product-item__text Встраиваемая вытяжка
	.product-item__title
		a.text-body(href="#")  Asko CC4527S
	.product-item__icons.row.g-2
		.product-item__icon.product-item__icon--rating.col-auto
			+icon("star")
			| 4.8
		.product-item__icon.product-item__icon--comments.col-auto
			+icon("chart")
			| 4
		.product-item__icon.product-item__icon--status.col-auto
			.product-item__ball(style="background: #35BE73")
			| В наличии
mixin prod-footer(h)
	.product-item__footer.row.g-1.align-items-end
		.col
			.product-item__prices
				.product-item__price-old 89 000 ₽
				.product-item__price-new 86 900 ₽
			.product-item__purchase
				.product-item__purchase-img-wrap: img(src="img/purchase-1.png", alt="")
				.product-item__purchase-img-wrap: img(src="img/purchase-2.png", alt="")
		if !h
			.col-auto
				.product-item__btn.btn.btn-success(href='#').active
					+icon("basket")
					+icon("check")
mixin product-item-rew(i, t, p ,pr)
	+b.ARTICLE.product-item--rew
		+prod-head("hide")
		+prod-img(i)
		+e.caption
			+prod-caption()
			+prod-footer()
	// /.product-item

mixin product-item(i, t, p ,pr)
	+b.ARTICLE.product-item
		+prod-head()
		+prod-img(i)
		+e.caption
			+prod-caption()
			+prod-footer()
	// /.product-item

mixin product-item-compare-sm(i, t, p ,pr)
	+b.ARTICLE.product-item--ac-sm
		.row
